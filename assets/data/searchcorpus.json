---
layout: null
---
[
{%- assign first = true -%}
{%- for post in site.posts -%}
  {%- unless first -%},{%- endunless -%}
  {
    "title"    : {{ post.title | strip_html | jsonify }},
    "category" : {{ post.tags | join: ', ' | jsonify }},
    "url"      : {{ post.url | absolute_url | jsonify }},
    "date"     : {{ post.date | date: "%B %e, %Y" | jsonify }}
  }
  {%- assign first = false -%}
{%- endfor -%}
{%- for page in site.html_pages -%}
  {%- if page.title != nil and page.url != "/assets/data/searchcorpus.json" -%}
    {%- unless first -%},{%- endunless -%}
    {
      "title"    : {{ page.title | strip_html | jsonify }},
      "category" : {{ page.tags | join: ', ' | jsonify }},
      "url"      : {{ page.url | absolute_url | jsonify }},
      "date"     : {{ page.date | date: "%B %e, %Y" | jsonify }}
    }
    {%- assign first = false -%}
  {%- endif -%}
{%- endfor -%}
]
