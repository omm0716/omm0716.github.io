---
layout: null
---
[
{%- assign first = true -%}
{%- for post in site.posts -%}
  {%- unless first -%},{%- endunless -%}
  {
    "title"    : {{ post.title | strip_html | jsonify }},
    "tags"     : {{ post.tags | join: ', ' | jsonify }},
    "url"      : {{ post.url | absolute_url | jsonify }},
    "date"     : {{ post.date | date: "%B %e, %Y" | jsonify }}
  }
  {%- assign first = false -%}
{%- endfor -%}
]
